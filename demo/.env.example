# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Anthropic — plugin reads ANTHROPIC_API_KEY automatically
ANTHROPIC_API_KEY=your_anthropic_api_key

# ElevenLabs — plugin reads ELEVEN_API_KEY automatically
ELEVEN_API_KEY=your_elevenlabs_api_key

# Voice ID — défaut : YxrwjAKoUKULGd0g8K9Y (à copier dans .env)
ELEVENLABS_VOICE_ID=YxrwjAKoUKULGd0g8K9Y

# Dashboard integration (dalia-call-backend Phase 6)
DASHBOARD_WEBHOOK_URL=https://your-dentalos-app.vercel.app
DASHBOARD_WEBHOOK_SECRET=your_shared_secret_64_hex
DASHBOARD_INTEGRATION_ENABLED=false
