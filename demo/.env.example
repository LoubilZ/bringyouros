# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Anthropic — plugin reads ANTHROPIC_API_KEY automatically
ANTHROPIC_API_KEY=your_anthropic_api_key

# ElevenLabs — plugin reads ELEVEN_API_KEY automatically
ELEVEN_API_KEY=your_elevenlabs_api_key

# Voice ID — défaut : YxrwjAKoUKULGd0g8K9Y (à copier dans .env)
ELEVENLABS_VOICE_ID=YxrwjAKoUKULGd0g8K9Y

# Patient/devis — ID du patient mock (1=Jean Dupont, 2=Marie Lefevre, 3=Pierre Martin)
DEVIS_ID=1
